{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2021"],
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "assets/toolchain-inhouse/template/src/**/*.tsx",
    "../template/src/**/*.tsx"
  ],
  "exclude": [
    "assets/toolchain-quartz/**",
    "node_modules",
    "assets/toolchain-inhouse/template/vite.config.ts"
  ]
}
