{
  "name": "obsidian-github-publish",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "build:advanced": "PLUGIN_SHOW_ADVANCED_SETTINGS=true node esbuild.config.mjs production",
    "build:plugin": "npm run sync:toolchain && npm run build",
    "build:plugin:advanced": "npm run sync:toolchain && npm run build:advanced",
    "dev": "node esbuild.config.mjs",
    "dev:advanced": "PLUGIN_SHOW_ADVANCED_SETTINGS=true node esbuild.config.mjs",
    "sync:toolchain": "node scripts/sync-quartz-toolchain.mjs",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/parser": "^8.62.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1"
  }
}
