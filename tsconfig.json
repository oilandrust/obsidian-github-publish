{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2021"]
  },
  "include": ["**/*.ts"],
  "exclude": ["assets/toolchain-quartz/**", "node_modules", "telemetry/worker/**"]
}
