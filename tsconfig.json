{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strictNullChecks": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["plugin/**/*.ts"],
  "exclude": ["**/node_modules", "plugin/assets/toolchain-quartz/**"]
}
